<!DOCTYPE html><html lang="es"><head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Mi Wishlist</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head><body>
<div class="admin-wrap">
  <aside class="admin-sidebar">
    <div class="store-brand"><i class="bi bi-person-circle me-2"></i><span>Mi cuenta</span></div>
    <nav>
      <a href="/customer/dashboard"><i class="bi bi-grid"></i> Mi cuenta</a>
      <a href="/customer/orders"><i class="bi bi-bag"></i> Mis compras</a>
      <a href="/customer/wishlist" class="active"><i class="bi bi-heart"></i> Wishlist</a>
      <a href="/products"><i class="bi bi-shop"></i> Explorar tiendas</a>
    </nav>
    <div class="sidebar-footer">
      <form method="POST" action="/user/logout">
        <button type="submit"><i class="bi bi-box-arrow-left me-2"></i>Cerrar sesión</button>
      </form>
    </div>
  </aside>
  <main class="admin-content">
    <div class="admin-topbar">
      <h1><i class="bi bi-heart me-2"></i>Mi Wishlist</h1>
      <a href="/products" class="btn btn-outline btn-sm">Seguir explorando</a>
    </div>
    <% if (!items || items.length === 0) { %>
      <div class="admin-card">
        <div class="admin-card-body text-center py-5">
          <i class="bi bi-heart" style="font-size:3rem;color:var(--border)"></i>
          <h5 class="mt-3 text-muted">Tu wishlist está vacía</h5>
          <a href="/products" class="btn btn-primary mt-3">Explorar productos</a>
        </div>
      </div>
    <% } else { %>
      <div class="row g-3">
        <% items.forEach(item => { %>
        <div class="col-sm-6 col-md-4 col-lg-3">
          <div class="admin-card h-100">
            <img src="<%= item.product.imageUrl %>" alt="<%= item.product.name %>"
                 style="width:100%;height:160px;object-fit:cover"
                 onerror="this.src='/images/placeholder.jpg'">
            <div class="admin-card-body">
              <div class="fw-semibold mb-1"><%= item.product.name %></div>
              <% if (item.product.store) { %>
                <div class="text-muted small mb-2"><%= item.product.store.name %></div>
              <% } %>
              <div style="color:var(--accent);font-weight:800;font-size:1.1rem;margin-bottom:12px">
                $<%= parseFloat(item.product.price).toFixed(2) %>
              </div>
              <div class="d-flex gap-2">
                <a href="/products/<%= item.product.id %>" class="btn btn-primary btn-sm flex-fill">
                  <i class="bi bi-bag-plus me-1"></i>Ver
                </a>
                <form method="POST" action="/customer/wishlist/remove/<%= item.product.id %>">
                  <button type="submit" class="btn btn-outline btn-sm" title="Quitar">
                    <i class="bi bi-heart-fill" style="color:var(--danger)"></i>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    <% } %>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body></html>
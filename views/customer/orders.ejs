<!DOCTYPE html><html lang="es"><head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Mis Compras</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head><body>
<div class="admin-wrap">
  <aside class="admin-sidebar">
    <div class="store-brand">
      <i class="bi bi-person-circle me-2"></i><span><%= (typeof user !== 'undefined' ? user : userSession).name %></span>
    </div>
    <nav>
      <a href="/customer/dashboard"><i class="bi bi-grid"></i> Mi cuenta</a>
      <a href="/customer/orders" class="active"><i class="bi bi-bag"></i> Mis compras</a>
      <a href="/customer/wishlist"><i class="bi bi-heart"></i> Wishlist</a>
      <a href="/products"><i class="bi bi-shop"></i> Explorar tiendas</a>
    </nav>
    <div class="sidebar-footer">
      <form method="POST" action="/user/logout">
        <button type="submit"><i class="bi bi-box-arrow-left me-2"></i>Cerrar sesión</button>
      </form>
    </div>
  </aside>
  <main class="admin-content">
    <div class="admin-topbar"><h1>Mis Compras</h1></div>
    <div class="admin-card">
      <% if (orders.length === 0) { %>
        <div class="admin-card-body text-center py-4">
          <i class="bi bi-bag-x" style="font-size:3rem;color:var(--border)"></i>
          <p class="text-muted mt-3">No has realizado compras aún. <a href="/products">Explorar tiendas →</a></p>
        </div>
      <% } else { %>
        <table class="admin-table">
          <thead><tr>
            <th>Orden</th><th>Fecha</th><th>Productos</th><th>Total</th><th>Estado</th><th></th>
          </tr></thead>
          <tbody>
            <% orders.forEach(order => { %>
            <tr>
              <td><strong>#<%= order.id %></strong></td>
              <td><%= new Date(order.createdAt).toLocaleDateString('es') %></td>
              <td><%= order.items.length %> artículo(s)</td>
              <td><strong style="color:var(--accent)">$<%= parseFloat(order.total).toFixed(2) %></strong></td>
              <td><span class="status-badge status-<%= order.status %>"><%= order.status %></span></td>
              <td><a href="/customer/orders/<%= order.id %>" class="btn btn-outline btn-sm">Ver detalle</a></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body></html>
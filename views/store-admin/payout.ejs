<!-- views/store-admin/payout.ejs -->
<!DOCTYPE html><html lang="es"><head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Cobrar — <%= store.name %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head><body>
<div class="admin-wrap">
  <%- include('./_sidebar', { store, page: 'payout' }) %>
  <main class="admin-content">
    <div class="admin-topbar">
      <h1><i class="bi bi-send me-2"></i>Solicitar Pago</h1>
    </div>

    <% if (success) { %>
      <div class="alert alert-success mb-4">
        <i class="bi bi-check-circle me-2"></i><%= success %>
      </div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-danger mb-4">
        <i class="bi bi-exclamation-circle me-2"></i><%= error %>
      </div>
    <% } %>

    <div class="row g-4">
      <div class="col-md-5">
        <div class="balance-card">
          <span class="balance-label">Balance de ventas</span>
          <span class="balance-amount">$<%= totalSales %></span>
          <div class="balance-sub">
            <i class="bi bi-paypal me-1"></i>
            <%= store.paypal_email || 'Email PayPal no configurado' %>
          </div>
        </div>
      </div>
      <div class="col-md-7">
        <div class="admin-card">
          <div class="admin-card-header">
            <h5>Solicitar transferencia</h5>
          </div>
          <div class="admin-card-body">
            <% if (store.paypal_email) { %>
            <form method="POST" action="/store-admin/payout">
              <div class="mb-3">
                <label class="form-label">Monto a solicitar ($)</label>
                <input type="number" step="0.01" name="amount"
                       class="form-control" min="1" max="<%= totalSales %>" required
                       placeholder="0.00">
              </div>
              <button type="submit" class="btn btn-success btn-lg w-100">
                <i class="bi bi-paypal me-2"></i>Enviar a PayPal Sandbox
              </button>
            </form>
            <% } else { %>
              <div class="text-center py-3">
                <i class="bi bi-paypal" style="font-size:2.5rem;color:var(--muted)"></i>
                <p class="text-muted mt-2">Configura tu email de PayPal para recibir pagos.</p>
                <a href="/store-admin/settings" class="btn btn-primary">
                  <i class="bi bi-gear me-2"></i>Ir a Configuración
                </a>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
</body></html>
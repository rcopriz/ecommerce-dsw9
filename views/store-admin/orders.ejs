<!DOCTYPE html><html lang="es"><head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Mis Pedidos</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head><body>
<div class="admin-wrap">
  <%- include('./_sidebar', { page: 'orders' }) %>
  <main class="admin-content">
    <div class="admin-topbar"><h1>Pedidos</h1></div>
    <div class="admin-card">
      <% if (orders.length === 0) { %>
        <div class="admin-card-body text-center py-4">
          <i class="bi bi-receipt" style="font-size:3rem;color:var(--border)"></i>
          <p class="text-muted mt-3">Aún no tienes pedidos.</p>
        </div>
      <% } else { %>
        <table class="admin-table">
          <thead><tr>
            <th>Orden</th><th>Cliente</th><th>Fecha</th>
            <th>Productos</th><th>Subtotal tienda</th><th>Estado</th>
          </tr></thead>
          <tbody>
            <% orders.forEach(o => { %>
            <tr>
              <td><strong>#<%= o.order.id %></strong></td>
              <td><%= o.order.firstName %> <%= o.order.lastName %>
                <div class="text-muted small"><%= o.order.email %></div>
              </td>
              <td><%= new Date(o.order.createdAt).toLocaleDateString('es') %></td>
              <td>
                <% o.items.forEach(item => { %>
                  <div class="small"><%= item.product.name %> x<%= item.quantity %></div>
                <% }) %>
              </td>
              <td><strong style="color:var(--accent)">
                $<%= o.items.reduce((s,i) => s + parseFloat(i.price)*i.quantity, 0).toFixed(2) %>
              </strong></td>
              <td>
                <span class="status-badge status-<%= o.order.status %>">
                  <%= o.order.status %>
                </span>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body></html>